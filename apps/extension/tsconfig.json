{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["chrome", "firefox-webext-browser", "bun-types"]
  },
  "include": [".wxt/**/*.ts", "src/**/*.ts", "wxt.config.ts"]
}
