# Extension runtime environment (Vite / WXT)
# Copy to .env.local for local builds.

# Hosted testing gateway and environment.
VITE_LATR_GATEWAY_URL=https://api.testing.latr.link
VITE_LATR_APP_ENV=test

# Register latr-link-extension-testing in latrkit.dev. Never commit the API key.
VITE_LATR_GATEWAY_CLIENT_ID=latr-link-extension-testing
VITE_LATR_GATEWAY_API_KEY=

# Public gateway metadata and the matching hosted callback.
VITE_ATPROTO_CLIENT_ID=https://api.testing.latr.link/oauth/extension-client-metadata.json
VITE_ATPROTO_REDIRECT_URI=https://testing.latr.link/extension/callback

# Web app for "Open library" link
VITE_LATR_WEB_URL=https://testing.latr.link
