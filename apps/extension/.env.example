# Extension runtime environment (Vite / WXT)
# Copy to .env.local for local builds.

# Gateway base URL (default: http://127.0.0.1:8080 when VITE_LATR_APP_ENV=local)
VITE_LATR_GATEWAY_URL=http://127.0.0.1:8080
VITE_LATR_APP_ENV=local

# Registered gateway client (required for hosted gateways with API keys)
VITE_LATR_GATEWAY_CLIENT_ID=latr-extension
VITE_LATR_GATEWAY_API_KEY=

# ATProto OAuth client metadata URL (must list this extension's redirect URI)
VITE_ATPROTO_CLIENT_ID=https://latr.link/extension/client-metadata.json

# Web app for "Open library" link
VITE_LATR_WEB_URL=http://127.0.0.1:3000
