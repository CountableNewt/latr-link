# L@tr gateway environment variables
# Copy to `.env` for local runs: export $(grep -v '^#' .env | xargs) && swift run LatrGateway

# --- Server ---
# HTTP listen port (Fly sets this automatically).
PORT=8080

# Deployment tier: local | dev | prod | test
# Defaults several auth policies when unset (see below).
APP_ENV=local

# PLC directory base URL for PDS resolution.
PLC_URL=https://plc.directory

# --- OAuth client allowlist (user access tokens) ---
# When true, JWT client_id / azp / aud must match OAUTH_GATEWAY_ALLOWED_CLIENT_IDS.
# Default: true when APP_ENV=prod, false otherwise.
# OAUTH_GATEWAY_REQUIRE_KNOWN_CLIENT=false

# Comma- or whitespace-separated OAuth client metadata URLs.
# OAUTH_GATEWAY_ALLOWED_CLIENT_IDS=https://latr.link/client-metadata.json,https://latr-link-dev-gateway.fly.dev/oauth/client-metadata.json

# SPA origin for redirect_uris when serving /oauth/client-metadata.json from the gateway.
# Set on the dev Fly app when testing.latr.link is deployment-protected (Vercel auth).
# OAUTH_PUBLIC_ORIGIN=https://testing.latr.link

# --- Registered gateway clients (API keys) ---
# When true, every /v1/latr/* request must include X-Latr-Client-Id and X-Latr-API-Key.
# Default: true when APP_ENV=prod, false otherwise.
# LATR_GATEWAY_REQUIRE_CLIENT_API_KEY=false

# Optional bootstrap credentials (comma/semicolon separated client-id=secret pairs).
# Bootstrap clients cannot be revoked via the registration API.
# LATR_GATEWAY_CLIENT_API_KEYS=latr-web=replace-me

# JSON file for client credentials registered via POST /v1/latr/clients/register.
# Default: ./data/client-registry.json (relative to the gateway working directory).
# On Fly, mount a volume at /data and set LATR_GATEWAY_CLIENT_REGISTRY_PATH=/data/client-registry.json
# LATR_GATEWAY_CLIENT_REGISTRY_PATH=./data/client-registry.json

# Shared secret for client registration/list/revoke routes.
# Required in dev/prod. Omitted in APP_ENV=local for open registration during development.
# LATR_GATEWAY_CLIENT_REGISTRATION_SECRET=replace-me
